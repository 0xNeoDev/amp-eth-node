# amp-eth-node version pins — single source of truth for all image tags
# Override locally in .env.local (not tracked by git)

# Ethereum clients — always pin to exact tags in production
RETH_VERSION=v1.11.3
LIGHTHOUSE_VERSION=v6.0.1

# Amp — pin to a release tag; override in .env.local if needed
AMP_VERSION=v0.1.0

# Infrastructure
POSTGRES_VERSION=16-alpine
GRAFANA_VERSION=11.4.0
PROMETHEUS_VERSION=v3.1.0
OTEL_COLLECTOR_VERSION=0.115.1

# Network: mainnet or sepolia
ETH_NETWORK=mainnet

# Reth
RETH_HTTP_PORT=8545
RETH_WS_PORT=8546
RETH_AUTH_PORT=8551
RETH_P2P_PORT=30303
RETH_METRICS_PORT=9001

# Lighthouse
LIGHTHOUSE_P2P_PORT=9000
LIGHTHOUSE_HTTP_PORT=5052
LIGHTHOUSE_METRICS_PORT=5054

# Lighthouse checkpoint sync (speeds up initial sync significantly)
# Mainnet: https://mainnet.checkpoint.sigp.io
# Sepolia: https://sepolia.beaconstate.info
LIGHTHOUSE_CHECKPOINT_SYNC_URL=https://mainnet.checkpoint.sigp.io

# Amp ports
AMP_FLIGHT_PORT=1602
AMP_JSONL_PORT=1603
AMP_ADMIN_PORT=1610

# PostgreSQL
POSTGRES_USER=amp
POSTGRES_PASSWORD=amp
POSTGRES_DB=amp

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
