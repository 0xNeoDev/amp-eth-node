# Local overrides — copy to .env.local and edit
# This file is NOT tracked by git

# Override network for development
# ETH_NETWORK=sepolia
# LIGHTHOUSE_CHECKPOINT_SYNC_URL=https://sepolia.beaconstate.info

# Production PostgreSQL credentials
# POSTGRES_PASSWORD=a-strong-random-password

# Grafana credentials
# GRAFANA_ADMIN_PASSWORD=a-strong-random-password

# NVMe bind mount paths for production (used in docker-compose.prod.yml)
# RETH_DATA_DIR=/mnt/nvme0/reth
# LIGHTHOUSE_DATA_DIR=/mnt/nvme0/lighthouse
# AMP_DATA_DIR=/mnt/nvme0/amp
# POSTGRES_DATA_DIR=/mnt/nvme0/postgres

# --- Arbitrum One L2 ---
# NVMe bind mount paths for L2 production
# NITRO_L2_DATA_DIR=/mnt/nvme0/nitro-l2
# AMP_L2_DATA_DIR=/mnt/nvme0/amp-l2

# --- Orbit L3 chain (Arbitrum Nitro) ---
# Parent chain RPC URL (required for Orbit mode)
# Self-hosted L2: NITRO_PARENT_CHAIN_URL=http://nitro-l2:8547
# External RPC:   NITRO_PARENT_CHAIN_URL=https://arb-mainnet.g.alchemy.com/v2/<key>
# NITRO_PARENT_CHAIN_URL=

# Testnet chain ID
# ORBIT_CHAIN_ID=19411

# NVMe bind mount paths for Orbit production
# NITRO_DATA_DIR=/mnt/nvme0/nitro
# AMP_ORBIT_DATA_DIR=/mnt/nvme0/amp-orbit
